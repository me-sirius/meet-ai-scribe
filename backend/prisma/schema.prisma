generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  meetings     Meeting[]
}

model Meeting {
  id                     String           @id @default(uuid()) @db.Uuid
  runId                  String           @unique
  userId                 String           @db.Uuid
  user                   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  meetLink               String
  participantName        String
  joinAsGuest            Boolean          @default(false)
  status                 String           @default("launching")
  summary                String           @default("") @db.Text
  transcript             String           @default("") @db.Text
  transcriptLineCount    Int              @default(0)
  captureDurationSeconds Int              @default(0)
  joinButtonLabel        String           @default("")
  pendingApproval        Boolean          @default(false)
  pendingAuth            Boolean          @default(false)
  captureEndReason       String           @default("")
  errorMessage           String           @default("") @db.Text
  joinedAt               DateTime?
  endedAt                DateTime?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  transcriptLines        TranscriptLine[]

  @@index([userId, createdAt])
}

model TranscriptLine {
  id        Int      @id @default(autoincrement())
  meetingId String   @db.Uuid
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  lineIndex Int
  ts        DateTime?
  text      String   @db.Text
  createdAt DateTime @default(now())

  @@index([meetingId, lineIndex])
}
