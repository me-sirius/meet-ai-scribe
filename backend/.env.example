PORT=4000
GEMINI_API_KEY=your_gemini_api_key
DATABASE_URL=postgresql://postgres.your-project-ref:your_db_password@aws-1-your-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.your-project-ref:your_db_password@aws-1-your-region.pooler.supabase.com:5432/postgres

CHROME_AUTOMATION_USER_DATA_DIR=chrome-bot-profile
CHROME_PROFILE_DIRECTORY=
CHROME_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

TRANSCRIPT_CAPTURE_SECONDS=180
TRANSCRIPT_IDLE_GRACE_SECONDS=20
TRANSCRIPT_MAX_CAPTURE_SECONDS=1800
MEET_FAST_PREJOIN_TIMEOUT_MS=3000
MEET_FAST_JOIN_TIMEOUT_MS=7000
MEET_KEEP_BROWSER_OPEN_ON_PENDING=true
